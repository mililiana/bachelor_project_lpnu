# API Keys — Copy this file to .env and fill in your keys
# DO NOT commit .env file with actual keys!

# Google Gemini API Key (default LLM backend)
GOOGLE_API_KEY=your_gemini_api_key_here

# Set to "true" to use local LapaLLM model instead of Gemini API
# Requires GPU (CUDA) and torch + transformers installed
# USE_LAPA=false
